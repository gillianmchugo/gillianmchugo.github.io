@online{ogradyetal2025biorxiv,
 abstract = {Bovine tuberculosis (bTB) remains recalcitrant to eradication in many endemic countries where current diagnostics are suboptimal. Mycobacterium bovis causes bTB and is closely related to Mycobacterium tuberculosis, which causes human tuberculosis (hTB). Although blood-based mRNA biomarkers identified through machine learning can discriminate hTB-positive from hTB-negative individuals, similar approaches have not been explored for bTB. Here, we use RNA-seq and machine learning to investigate the utility of blood mRNA as a host-response biomarker for bTB. We identify a 30-gene signature and a 273-gene elastic net classifier that differentiate bTB-positive from bTB-negative cattle, achieving area under the curve (AUC) values of 0.986/0.900 for the former and 0.968/0.938 for the latter in training and testing, respectively. Additionally, we show that these classifiers distinguish bTB-positive cattle from cattle infected with other microbial pathogens (AUC $>$= 0.819). These mRNA-based classifiers represent a promising tool for augmenting current diagnostics to advance global bTB eradication efforts.},
 annotation = {PPR: PPR1078773},
 author = {O'Grady, John F. and Ivich, Adriana and McHugo, Gillian P. and Khan, Adnan and Hall, Thomas J. and Faherty O'Donnell, Sarah L. and Correia, Carolina N. and Browne, John A. and Riggio, Valentina and Prendergast, James G. D. and Clark, Emily L. and Pausch, Hubert and Meade, Kieran G. and Gormley, Isobel Claire and Gormley, Eamonn and Gordon, Stephen V. and Greene, Casey S. and MacHugh, David E.},
 date = {2025-09-04},
 doi = {10.1101/2025.09.01.673540},
 eprint = {2025.09.01.673540},
 eprinttype = {bioRxiv},
 issn = {2692-8205},
 number = {2025.09.01.673540},
 pubstate = {prepublished},
 title = {A new diagnostic modality for bovine tuberculosis: accurate and robust classification of infected cattle using transcriptomics and machine learning},
 url = {https://www.biorxiv.org/content/10.1101/2025.09.01.673540}
}

